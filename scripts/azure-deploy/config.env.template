# Azure Deployment Configuration
# Copy this file to config.env and fill in your values

# Azure Configuration
AZURE_RESOURCE_GROUP="mcp-gateway-dev-rg"
AZURE_LOCATION="eastus2"

# Azure Container Registry
ACR_NAME="agwimages" #must consist alpahnumerical symbols only
IMAGE_NAME="agentgateway"
IMAGE_TAG="latest"

# Azure File Share
STORAGE_ACCOUNT_NAME="agwconfigrg"
FILE_SHARE_NAME="configshare"

# Azure Container Instance
ACI_NAME="agw-dev-auto"
ACI_DNS_NAME="agentgateway"
ACI_CPU="1.0"
ACI_MEMORY="1.5"
ACI_OS_TYPE="Linux"  # Linux or Windows

# Application Configuration
CONFIG_FILE_PATH="../../examples/basic/config.yaml"

# Exposed Ports (space-separated list)
EXPOSED_PORTS="3000 3001 15000"

# Mount Configuration
MOUNT_PATH="/config"
CONFIG_FILE_NAME="config.yaml"
